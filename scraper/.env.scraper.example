# Scraper configuration - S3/R2 credentials for image hosting
# COPY THIS FILE and fill in real values. NEVER commit real credentials.
#
# Required env vars:
#   S3_ACCESS_KEY_ID     - access key
#   S3_SECRET_ACCESS_KEY - secret key
#   S3_BUCKET            - bucket name (e.g. "perfumes-el-pocho")
#   S3_REGION            - region (e.g. "us-east-1")
#   S3_ENDPOINT_URL      - optional. Set only for R2/MinIO/etc.
#                          R2 example: https://<account>.r2.cloudflarestorage.com
#   S3_PUBLIC_URL        - optional. CDN/public URL prefix.
#                          If unset, defaults to https://<bucket>.s3.<region>.amazonaws.com
#                          R2 example: https://images.perfumeselpocho.com

S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_BUCKET=perfumes-el-pocho
S3_REGION=us-east-1
# S3_ENDPOINT_URL=
# S3_PUBLIC_URL=
